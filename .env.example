# ── API-Keys ──────────────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
MARKETAUX_API_KEY=your_marketaux_key_here
SIMFIN_API_KEY=your_simfin_api_key_here

# ── Telegram-Bot ──────────────────────────────────────────────────────────────
# Token von @BotFather erhalten; Chat-ID nach Anschreiben des Bots via:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# ── Datenbank ─────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/aidepot.db

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCAN_HOUR_UTC=6
SCAN_MINUTE_UTC=0

# ── Rate-Limits (bei API-Upgrade anpassen) ────────────────────────────────────
FINNHUB_CALLS_PER_MINUTE=60
ALPHA_VANTAGE_CALLS_PER_DAY=25
MARKETAUX_CALLS_PER_DAY=100

# ── Anwendung ─────────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
